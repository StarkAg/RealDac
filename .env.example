# RealDac environment variables
#
# Copy to `.env` (or `.env.local`) and edit. Both are gitignored.

# ─── Convex deployment URL ───
#
# RealDac uses Convex to persist "last selected track" per room (for cross-device
# recovery). Realtime sync itself runs over Socket.IO, so the app remains usable
# even when Convex is unreachable — but you'll get console warnings.
#
# To run RealDac against your own Convex deployment:
#   1. npx convex dev    (in this folder, first time only)
#   2. Convex CLI writes the deployment URL into .env.local automatically.
#   3. Restart `npm run dev:all`.
#
# Without this, the client falls back to a shared deployment (which may not
# have the `realdacRooms` table — expect Convex query errors that are handled
# gracefully by the error boundary).
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ─── API server port (optional) ───
# PORT=3200
